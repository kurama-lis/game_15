<style>
    .bg-gradient-nature {
        background: linear-gradient(135deg, #10b981, #047857);
    }
    .form-card {
        background: rgba(255, 255, 245, 0.96);
        border-radius: 2rem;
        padding: 1.5rem;
        box-shadow: 0 8px 20px rgba(0,0,0,0.1);
        border: 1px solid rgba(255,245,200,0.6);
        transition: transform 0.2s;
    }
    .form-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 12px 25px rgba(0,0,0,0.15);
    }
    .input-field {
        width: 100%;
        padding: 0.7rem 1.2rem;
        border: 1px solid #d1d5db;
        border-radius: 2rem;
        background: white;
        transition: all 0.2s;
    }
    .input-field:focus {
        outline: none;
        border-color: #10b981;
        box-shadow: 0 0 0 3px rgba(16,185,129,0.2);
    }
    .divider {
        display: flex;
        align-items: center;
        text-align: center;
        margin: 1.5rem 0;
    }
    .divider::before, .divider::after {
        content: '';
        flex: 1;
        border-bottom: 1px solid #cbd5e0;
    }
    .divider span {
        margin: 0 0.75rem;
        color: #4a5568;
        font-size: 0.9rem;
        background: rgba(255,255,245,0.96);
        padding: 0 0.5rem;
    }
    .btn-nature {
        background: #10b981;
        color: white;
        font-weight: bold;
        padding: 0.6rem 1.5rem;
        border-radius: 2rem;
        border: none;
        cursor: pointer;
        transition: all 0.2s;
        width: 100%;
    }
    .btn-nature:hover {
        background: #059669;
        transform: translateY(-2px);
        box-shadow: 0 5px 10px rgba(0,0,0,0.1);
    }
    .bubbles {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 0;
    }
    .bubble {
        position: absolute;
        background: rgba(255,255,240,0.2);
        border-radius: 50%;
        animation: float 20s infinite;
    }
    @keyframes float {
        0% { transform: translateY(100vh) scale(0); opacity: 0; }
        20% { opacity: 0.5; }
        80% { opacity: 0.5; }
        100% { transform: translateY(-20vh) scale(1); opacity: 0; }
    }
    h2 {
        color: #065f46;
        font-size: 1.5rem;
        margin-bottom: 1rem;
        text-align: center;
    }
    .flash-message {
        border-radius: 2rem;
        padding: 0.75rem 1rem;
        margin-bottom: 1.2rem;
        text-align: center;
    }
    .flash-alert { background: #fee2e2; border-left: 4px solid #ef4444; }
    .flash-notice { background: #d1fae5; border-left: 4px solid #10b981; }
</style>

<div class="bg-gradient-nature" style="min-height:100vh; position:relative; overflow:hidden;">
  <!-- Пузырьки -->
  <div class="bubbles">
    <% (1..18).each do |i| %>
      <div class="bubble" style="
      width: <%= rand(40..110) %>px;
        height: <%= rand(40..110) %>px;
        left: <%= rand(5..95) %>%;
        animation-duration: <%= rand(8..20) %>s;
        animation-delay: <%= rand(0..15) %>s;
        opacity: <%= rand(0.2..0.5) %>;
      "></div>
    <% end %>
  </div>

  <div style="position:relative; z-index:1; min-height:100vh; display:flex; align-items:center; justify-content:center; padding:2rem;">
    <div style="max-width:500px; width:100%;">
      <h1 style="text-align:center; color:#ffffff; font-size:2.2rem; margin-bottom:1.5rem; text-shadow: 2px 2px 4px rgba(0,0,0,0.2);">🧩 Пятнашки 15 🧩</h1>

      <!-- Блок с сообщениями -->
      <% if flash[:alert] %>
        <div class="flash-message flash-alert"><%= flash[:alert] %></div>
      <% end %>
      <% if flash[:notice] %>
        <div class="flash-message flash-notice"><%= flash[:notice] %></div>
      <% end %>

      <!-- Карточка входа -->
      <div class="form-card" style="margin-bottom: 1rem;">
        <h2>🔐 Вход</h2>
        <%= form_with url: login_path, local: true, class: "space-y-3" do |f| %>
          <div>
            <%= f.email_field :email, placeholder: "Email", class: "input-field", required: true %>
          </div>
          <div>
            <%= f.password_field :password, placeholder: "Пароль", class: "input-field", required: true %>
          </div>
          <%= f.submit "Войти", class: "btn-nature" %>
        <% end %>
      </div>

      <!-- Разделитель -->
      <div class="divider">
        <span>или</span>
      </div>

      <!-- Карточка регистрации -->
      <div class="form-card">
        <h2>📝 Регистрация</h2>
        <%= form_with url: signup_path, local: true, method: :post, class: "space-y-3" do |f| %>
          <div>
            <%= f.email_field :email, name: "user[email]", placeholder: "Email", class: "input-field", required: true %>
          </div>
          <div>
            <%= f.text_field :nickname, name: "user[nickname]", placeholder: "Имя (для рекордов)", class: "input-field" %>
          </div>
          <div>
            <%= f.password_field :password, name: "user[password]", placeholder: "Пароль (мин. 6 символов)", class: "input-field", required: true, minlength: 6 %>
          </div>
          <div>
            <%= f.password_field :password_confirmation, name: "user[password_confirmation]", placeholder: "Подтверждение пароля", class: "input-field", required: true %>
          </div>
          <%= f.submit "Зарегистрироваться", class: "btn-nature" %>
        <% end %>
      </div>
    </div>
  </div>
</div>