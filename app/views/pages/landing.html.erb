<!-- Приветственная страница с формами входа и регистрации -->
<div class="min-h-screen bg-gradient-to-br from-green-400 to-emerald-800 flex items-center justify-center p-4">
  <div class="bg-white/90 backdrop-blur-sm rounded-2xl shadow-xl p-8 max-w-md w-full">
    <h1 class="text-3xl font-bold text-center text-emerald-800 mb-8">
      Пятнашки 15
    </h1>

    <!-- Сообщения об ошибках -->
    <% if flash[:alert] %>
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
        <%= flash[:alert] %>
      </div>
    <% end %>

    <!-- ФОРМА ВХОДА -->
    <div class="mb-6">
      <h2 class="text-xl font-semibold text-center text-gray-700 mb-4">Вход</h2>
      <%= form_with url: login_path, local: true, class: "space-y-4" do |f| %>
        <div class="mb-3">
          <%= f.email_field :email, class: "w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500", placeholder: "Email", required: true %>
        </div>
        <div class="mb-3">
          <%= f.password_field :password, class: "w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500", placeholder: "Пароль", required: true %>
        </div>
        <%= f.submit "Войти", class: "w-full bg-emerald-600 text-white py-2 rounded-lg hover:bg-emerald-700 transition cursor-pointer" %>
      <% end %>
    </div>

    <!-- ФОРМА РЕГИСТРАЦИИ -->
    <div>
      <h2 class="text-xl font-semibold text-center text-gray-700 mb-4">Регистрация</h2>
      <%= form_with url: signup_path, local: true, method: :post, class: "space-y-4" do |f| %>
        <div class="mb-3">
          <%= f.email_field :email, name: "user[email]", class: "w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500", placeholder: "Email", required: true %>
        </div>
        <div class="mb-3">
          <%= f.text_field :nickname, name: "user[nickname]", class: "w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500", placeholder: "Имя (для рекордов)" %>
        </div>
        <div class="mb-3">
          <%= f.password_field :password, name: "user[password]", class: "w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500", placeholder: "Пароль (мин. 6 символов)", required: true, minlength: 6 %>
        </div>
        <div class="mb-3">
          <%= f.password_field :password_confirmation, name: "user[password_confirmation]", class: "w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500", placeholder: "Подтверждение пароля", required: true %>
        </div>
        <%= f.submit "Зарегистрироваться", class: "w-full bg-emerald-600 text-white py-2 rounded-lg hover:bg-emerald-700 transition cursor-pointer" %>
      <% end %>
    </div>
  </div>
</div>