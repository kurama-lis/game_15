<div class="min-h-screen bg-gradient-to-br from-blue-400 to-purple-600 flex items-center justify-center p-4">
  <div class="bg-white rounded-2xl shadow-xl p-8 max-w-md w-full">
    <h1 class="text-3xl font-bold text-center text-gray-800 mb-8">🧩 Пятнашки 15 🧩</h1>

    <% if flash[:alert] %>
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
        <%= flash[:alert] %>
      </div>
    <% end %>

    <!-- Форма входа -->
    <%= form_with url: login_path, local: true, class: "space-y-4" do |f| %>
      <div>
        <%= f.label :email, "Email", class: "block text-gray-700 font-medium mb-1" %>
        <%= f.email_field :email, class: "w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500", required: true %>
      </div>

      <div>
        <%= f.label :password, "Пароль", class: "block text-gray-700 font-medium mb-1" %>
        <%= f.password_field :password, class: "w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500", required: true %>
      </div>

      <%= f.submit "Войти", class: "w-full bg-blue-600 text-white py-2 rounded-lg hover:bg-blue-700 transition cursor-pointer" %>
    <% end %>

    <div class="text-center mt-4">
      Нет аккаунта? <%= link_to "Зарегистрироваться", signup_path, class: "text-blue-600 hover:underline" %>
    </div>
  </div>
</div>